# ─────────────────────────────────────────────
# PropTax Engine — Configuration
# Copier en .env et adapter
# ─────────────────────────────────────────────

# --- Server ---
PORT=3000
HOST=0.0.0.0

# --- MongoDB (optionnel — sans URI, seules les couches Calcul + Documents démarrent) ---
MONGODB_URI=mongodb://localhost:27017/proptax

# --- API Keys (SHA-256 hash, séparés par virgule) ---
# Générer : echo -n "votre-clé" | shasum -a 256
API_KEYS=

# --- Rate Limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
